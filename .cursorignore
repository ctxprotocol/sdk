# Minimal secret-blocking for standalone SDK clones.
# Documents workspace users: the parent Documents/.cursorignore also applies.

**/.env
**/.env.*
**/.env.local
**/*.pem
**/*.key
**/*.p12
**/credentials.json
**/secrets.json
**/config.json
**/key_pair.pem

# Contributor local env under examples/server
examples/server/**/.env
examples/server/**/.env.*

# Build and dependency outputs
**/node_modules/**
**/dist/**
