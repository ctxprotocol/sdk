# Financial Modeling Prep MCP Server configuration
PORT=4011

# FMP API key (required). Get one at https://site.financialmodelingprep.com/developer/docs
# Free tier works for US stocks + most stable endpoints at limited daily volume.
FMP_API_KEY=replace-with-your-fmp-api-key

# Optional local debugging switch (DO NOT enable in production).
# When true, /mcp auth middleware is bypassed for direct endpoint testing.
FMP_ALLOW_UNAUTH_MCP=false

# Optional defaults / upstream tuning
FMP_DEFAULT_EXECUTE_USD=0.001
FMP_DEFAULT_STATEMENT_LIMIT=8
FMP_DEFAULT_NEWS_LIMIT=25
FMP_REQUEST_TIMEOUT_MS=20000
