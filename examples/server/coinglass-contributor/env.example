# Coinglass API Key (Required)
# Get your API key from https://www.coinglass.com/pricing
COINGLASS_API_KEY=your_api_key_here

# API Plan (Optional, defaults to hobbyist)
# Set to professional/pro/enterprise to disable hobby endpoint guard
COINGLASS_PLAN=hobbyist

# Max upstream requests per minute for this key (Optional, defaults to 60)
# Use your tier-specific quota from Coinglass dashboard/headers.
COINGLASS_RATE_LIMIT=60

# Server Port (Optional, defaults to 4005)
PORT=4005

# Context middleware auth toggle (Optional, defaults to true)
# Set to false ONLY for controlled local/server testing.
CONTEXT_AUTH_ENABLED=true
