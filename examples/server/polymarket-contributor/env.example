# Polymarket MCP Server Configuration
PORT=4003

# No API keys required - this server uses public Polymarket APIs only.
# Portfolio context is fetched client-side and passed to the analyze_my_positions tool.

# Optional upstream pacing + retry tuning
POLYMARKET_GAMMA_RATE_LIMIT=180
POLYMARKET_CLOB_RATE_LIMIT=240
POLYMARKET_DATA_RATE_LIMIT=120
POLYMARKET_RETRY_ATTEMPTS=3
POLYMARKET_RETRY_BASE_BACKOFF_MS=450

# Optional local debugging switch (DO NOT enable in production).
# When true, /mcp auth middleware is bypassed for direct endpoint testing.
POLYMARKET_ALLOW_UNAUTH_MCP=false
